{
  "manifest_version": 3,
  "name": "Schedulrr - Quick Booking",
  "version": "1.0.0",
  "description": "Access your Schedulrr booking links, manage availability, and schedule meetings directly from your browser toolbar.",
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
